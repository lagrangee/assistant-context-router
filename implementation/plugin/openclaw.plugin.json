{
  "id": "assistant-context-router",
  "name": "Assistant Context Router",
  "description": "Project-centric command and prompt-context plugin for OpenClaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "registryPath": {
        "type": "string",
        "description": "Absolute path to projects/index.yaml"
      },
      "dataDir": {
        "type": "string",
        "description": "Optional plugin data directory override"
      }
    }
  },
  "runtime": {
    "entry": "./src/index.ts"
  }
}
